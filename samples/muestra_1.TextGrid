            xmin = 18.929995
            xmax = 20.129995
            text = ""
        intervals [10]:
            xmin = 20.129995
            xmax = 22.439995
            text = "porque se puede descolgar la atracción en cualquier momento"
        intervals [11]:
            xmin = 22.439995
            xmax = 27.359995
            text = ""
        intervals [12]:
            xmin = 27.359995
            xmax = 27.779995
            text = "que me muero"
