            xmin = 27.779995
            xmax = 47.279995
            text = ""
        intervals [14]:
            xmin = 47.279995
            xmax = 53.119995
            text = "la verdad es que no montarme y la- cuando solo era la feria no me suelo quedar debajo de las atracciones mirando como la gente se monta"
