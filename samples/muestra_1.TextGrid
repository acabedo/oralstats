            text = ""
        intervals [4]:
            xmin = 6.659995
            xmax = 9.559995
            text = "para mí la adrenalina se puede conseguir de otras formas"
        intervals [5]:
            xmin = 9.559995
            xmax = 10.309995
            text = ""
        intervals [6]:
            xmin = 10.309995
            xmax = 13.279995
            text = "como jugar un partido de fútbol y no montándome una atracción"
        intervals [7]:
            xmin = 13.279995
            xmax = 18.519995
            text = ""
        intervals [8]:
            xmin = 18.519995
            xmax = 18.929995
            text = "por supuesto"
