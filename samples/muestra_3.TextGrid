            text = "si nos centramos en la política la política viene de la antigua grecia y era un método para que así los gobernantes no tuviesen ese puesto durante toda su vida"
        intervals [3]:
            xmin = 8.832032
            xmax = 9.655032
            text = ""
        intervals [4]:
            xmin = 9.655032
            xmax = 15.824032
            text = "qué opinas que deberíamos volver a esa metodología de política en la cual tú gobernabas seis años y luego ya"
        intervals [5]:
            xmin = 15.824032
            xmax = 16.178032
            text = ""
        intervals [6]:
            xmin = 16.178032
            xmax = 17.425032
            text = "te quitaban y sí que tenías"
        intervals [7]:
            xmin = 17.425032
            xmax = 17.726032
            text = ""
        intervals [8]:
            xmin = 17.726032
            xmax = 20.116032
            text = "alguna ayuda económica pero ya no podías volver y"
        intervals [9]:
            xmin = 20.116032
            xmax = 20.620032
            text = ""
        intervals [10]:
            xmin = 20.620032
            xmax = 23.222032
            text = "ya no podías volver a aprovecharte de ese dinero"
        intervals [11]:
            xmin = 23.222032
            xmax = 23.363032
            text = ""
        intervals [12]:
            xmin = 23.363032
            xmax = 26.540032
            text = "o o deberíamos seguir con la política que estamos teniendo ahora"
        intervals [13]:
            xmin = 26.540032
            xmax = 57.144067
            text = ""
